    "stop (what|whatever) you('re| are) doing",
    "do not (continue|proceed|execute)",
    "halt (execution|immediately|all)",
    "emergency (stop|halt|abort)",
    "override: ",
    "\\[INST\\]",
    "<\\|im_start\\|>",
    "###SYSTEM###"
  ]
}
